<include>
  <extension name="agentic_contact_center_local_sip">
    <condition field="destination_number" expression="^(8600|acc)$">
      <action application="answer"/>
      <action application="set" data="acc_route=local_sip"/>
      <action application="set" data="acc_signalwire_ready=true"/>
      <action application="set" data="hangup_after_bridge=false"/>
      <action application="set" data="acc_return_audio=pipecat_verto_webrtc"/>
      <action application="set" data="acc_media_bridge=pipecat_verto_agent_leg"/>
      <action application="set" data="absolute_codec_string=opus,PCMU"/>
      <action application="bridge" data="${verto_contact(acc-pipecat@$${domain})}"/>
    </condition>
  </extension>
</include>

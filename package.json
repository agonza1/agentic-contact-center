{
  "name": "agentic-contact-center",
  "version": "0.1.0",
  "private": true,
  "description": "ClueCon 2026 agentic contact center POC scaffold",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "proof": "npm run build && node scripts/demo-proof.mjs",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "docker:app": "docker compose up --build app",
    "docker:proof": "sh -c 'LOCAL_UID=${LOCAL_UID:-$(id -u)} LOCAL_GID=${LOCAL_GID:-$(id -g)} docker compose run --rm proof'",
    "health:smoke": "node scripts/health-smoke.mjs --url http://127.0.0.1:8026/health",
    "docker:smoke": "sh -c 'cleanup(){ docker compose down --remove-orphans; }; trap cleanup EXIT; docker compose up --build -d app && node scripts/health-smoke.mjs --url http://127.0.0.1:8026/health'",
    "pipecat:check": "python3 scripts/pipecat-local-runtime.py --self-test",
    "pipecat:voice:install": "python3 -m pip install --target .pipecat-runtime -r requirements-pipecat-voice.txt",
    "pipecat:voice:check": "python3 scripts/pipecat-local-voice-bridge.py --check-sidecars",
    "pipecat:voice": "python3 scripts/pipecat-local-voice-bridge.py",
    "assert:export": "npm run build && node scripts/assert-export.mjs",
    "assert:viewer:install": "node scripts/assert-viewer.mjs --install-only",
    "assert:viewer": "node scripts/assert-viewer.mjs",
    "assert:full": "npm run assert:export && npm run assert:viewer",
    "proof:pipecat": "npm run pipecat:check && npm run proof --",
    "proof:bundle": "node scripts/agentic-call-center-proof.mjs",
    "proof:speech-enhancement": "npm run build && node scripts/speech-enhancement-spike-report.mjs",
    "sip:local-proof": "node scripts/local-sip-live-proof.mjs",
    "sip:self-test": "node scripts/local-sip-live-proof.mjs --self-test --out-dir artifacts/local-sip-selftest",
    "freeswitch:bridge": "node scripts/freeswitch-acc-bridge.mjs",
    "docker:freeswitch": "docker compose --profile freeswitch up --build app freeswitch",
    "docker:freeswitch:only": "docker compose --profile freeswitch up -d freeswitch --no-deps",
    "proof:live-sip-bundle": "node scripts/live-sip-proof-bundle.mjs",
    "proof:realtime-shim": "npm run build && node scripts/realtime-shim-proof.mjs",
    "browser-webrtc:check": "node scripts/browser-webrtc-readiness-smoke.mjs",
    "pipecat:voice:readiness": "node scripts/browser-webrtc-readiness-smoke.mjs",
    "browser-webrtc:live-proof": "node scripts/browser-webrtc-live-proof.mjs",
    "pipecat:webrtc:install": "python3 -m pip install --upgrade --target .pipecat-runtime -r requirements-pipecat-voice.txt",
    "pipecat:webrtc:check": "python3 scripts/pipecat-browser-webrtc-bridge.py --check-sidecars",
    "pipecat:webrtc": "python3 scripts/pipecat-browser-webrtc-bridge.py",
    "pipecat:webrtc:readiness": "node scripts/browser-webrtc-readiness-smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "typescript": "^5.8.3"
  }
}
